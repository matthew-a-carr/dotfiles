<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mattcarr.chezmoi-autosync</string>

    <key>ProgramArguments</key>
    <array>
        <!-- /bin/bash is 3.2 on macOS; some helpers we source (SDKMAN's
             sdkman-path-helpers.sh) use bash 4 syntax. Use the brewed
             bash so sourced files don't error with "bad substitution".
             Brewfile.common pins this binary. -->
        <string>/opt/homebrew/bin/bash</string>
        <string>-lc</string>
        <string>echo "--- $(date '+%Y-%m-%d %H:%M:%S') ---" &amp;&amp; /opt/homebrew/bin/chezmoi --no-tty --force update 2>&amp;1 &amp;&amp; /opt/homebrew/bin/chezmoi --no-tty --force re-add --keep-going 2>&amp;1</string>
    </array>

    <key>StartInterval</key>
    <integer>900</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>{{ .chezmoi.homeDir }}/Library/Logs/chezmoi-autosync.log</string>

    <key>StandardErrorPath</key>
    <string>{{ .chezmoi.homeDir }}/Library/Logs/chezmoi-autosync.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>{{ .chezmoi.homeDir }}</string>
    </dict>
</dict>
</plist>
