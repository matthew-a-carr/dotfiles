# fi

# Compilation flags
# export ARCHFLAGS="-arch $(uname -m)"

# Set personal aliases, overriding those provided by Oh My Zsh libs,
# plugins, and themes. Aliases can be placed here, though Oh My Zsh
# users are encouraged to define aliases within a top-level file in
# the $ZSH_CUSTOM folder, with .zsh extension. Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

alias ll='ls -la'
alias reward='cd ~/git/reward'
alias reward-job-api='cd ~/git/reward-job-api'
alias backstage='cd ~/git/backstage'
alias trs='cd ~/git/total-reward-statement-api'
alias sftp='cd ~/git/cloud-sftp'
alias puller='cd ~/git/pubsub_puller'
alias infra='cd ~/git/onehub-infrastructure'
alias profile='cd ~/git/profiles-api'
alias keycloak='cd ~/git/keycloak'
alias python="python3"
alias c="clear"
alias dotfiles="cd ~/git/dotfiles"

# chezmoi
alias cm="chezmoi"
alias cmd="chezmoi diff"
alias cma="chezmoi apply"
alias cmr="chezmoi re-add"
alias cme="chezmoi edit --apply"
alias csync="chezmoi re-add && echo '[csync] synced — auto-commit + auto-push handled by chezmoi'"
alias csynclog="tail -40 ~/Library/Logs/chezmoi-autosync.log"
alias csynctail="tail -f ~/Library/Logs/chezmoi-autosync.log"
alias csyncerr='grep -iE "error|conflict|rejected|fatal" ~/Library/Logs/chezmoi-autosync.log | tail -20'

# Claude
function load-mongo-dev() {
  export MONGODB_URI=$(op read "op://Employee/Mongo Dev/notesPlain")
}
function load-mongo-prod() {
  export MONGODB_URI=$(op read "op://Employee/Mongo Prod/notesPlain")
}
function claude-mongo-dev() {
  MONGODB_URI=$(op read "op://Employee/Mongo Dev/notesPlain") claude "$@"
}
function claude-mongo-prod() {
  MONGODB_URI=$(op read "op://Employee/Mongo Prod/notesPlain") claude "$@"
}

# Functions
function drmc()
{
    docker rm -f $(docker ps -aq)
}
function dri()
{
    docker rmi -f $(docker images -q)
}
function dexec()
{
    local container="${1}"
    local command="${2:-bash}"
    docker exec -it "${container}" "${command}"
}

source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Docker configuration
export TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE=/var/run/docker.sock
export TESTCONTAINERS_HOST_OVERRIDE=localhost
export DOCKER_HOST="unix://${HOME}/.colima/default/docker.sock"
export GOOGLE_CLOUD_PROJECT="benefex-onehub-dev"

#THIS MUST BE AT THE END OF THE FILE FOR SDKMAN TO WORK!!!
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] && source "$HOME/.sdkman/bin/sdkman-init.sh"

# Lazy-load NVM (~425ms saved)
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm node npm npx
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
  nvm "$@"
}
node() { nvm use default >/dev/null; unset -f node; node "$@"; }
npm() { nvm use default >/dev/null; unset -f npm; npm "$@"; }
npx() { nvm use default >/dev/null; unset -f npx; npx "$@"; }

export GPG_TTY=$(tty)

export PATH="/opt/homebrew/opt/influxdb@1/bin:/opt/homebrew/share/google-cloud-sdk/bin:$PATH"

# Added by Antigravity
export PATH="{{ .chezmoi.homeDir }}/.antigravity/antigravity/bin:$PATH"

eval "$(zoxide init zsh)"

# AsyncAPI CLI Autocomplete

ASYNCAPI_AC_ZSH_SETUP_PATH={{ .chezmoi.homeDir }}/Library/Caches/@asyncapi/cli/autocomplete/zsh_setup && test -f $ASYNCAPI_AC_ZSH_SETUP_PATH && source $ASYNCAPI_AC_ZSH_SETUP_PATH; # asyncapi autocomplete setup


